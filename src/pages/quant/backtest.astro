---
import BacktestRunner from '@/components/quant/backtest/BacktestRunner';
import FutureExpansion from '@/components/quant/backtest/FutureExpansion.astro';
import LearningNotes from '@/components/quant/backtest/LearningNotes.astro';
import Header from '@/components/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Quant Backtest"
  description="가격 데이터와 규칙 기반 전략을 이용해 투자 아이디어를 검증하는 백테스트 도구"
>
  <Header active="backtest" />
  <main class="page quant-lab-page">
    <section class="category-hero quant-lab-hero">
      <div>
        <p class="eyebrow">Quant Backtest Lab</p>
        <h1>Quant Backtest</h1>
      </div>
    </section>

    <BacktestRunner client:load />
    <FutureExpansion />
  </main>
</BaseLayout>

---
import Header from '@/components/Header.astro';
import SearchBox from '@/components/SearchBox.astro';
import DocList from '@/components/DocList.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { quantDocs } from '@/lib/docs';
---

<BaseLayout title="퀀트">
  <Header active="quant" />
  <main class="page">
    <section class="category-hero">
      <div>
        <p class="eyebrow">Quant Strategy</p>
        <h1>퀀트</h1>
        <p>유니버스, 팩터, 필터, 리밸런싱, 백테스트처럼 규칙 기반 투자에 필요한 개념을 정리합니다.</p>
      </div>
      <SearchBox />
    </section>
    <DocList docs={quantDocs} />
  </main>
</BaseLayout>

---
import SearchBox from './SearchBox.astro';

type Props = {
  active?: 'home' | 'stock' | 'quant' | 'backtest' | 'portfolio';
};

const { active = 'home' } = Astro.props;
const navItems = [
  { href: '/stock/', label: '주식', key: 'stock' },
  { href: '/quant/', label: '퀀트', key: 'quant' },
  { href: '/quant/backtest/', label: '백테스트 실험실', key: 'backtest' },
  { href: '/quant/portfolio/', label: '포트폴리오 구성', key: 'portfolio' },
];
---

<header class="site-header">
  <a class="brand" href="/" aria-label="Quantledge 홈">
    <span class="brand-mark"></span>
    <span>Quantledge</span>
  </a>
  <div class="header-search">
    <SearchBox compact label="Search" placeholder="Search for anything" />
  </div>
  <nav class="site-nav" aria-label="주요 메뉴">
    {
      navItems.map((item) => (
        <a class:list={['nav-link', active === item.key && 'active']} href={item.href}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
